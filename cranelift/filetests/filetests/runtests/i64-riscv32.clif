; run: %icmp_ult_i64(0, 0xFFFFFFFF_FFFFFFFF) == 1

function %shl_i64(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = ishl v0, v1
    return v2
}
; run: %shl_i64(1, 0) == 1
; run: %shl_i64(1, 1) == 2
; run: %shl_i64(1, 32) == 0x00000001_00000000
; run: %shl_i64(1, 63) == 0x80000000_00000000

function %shr_i64(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = ushr v0, v1
    return v2
}
; run: %shr_i64(0x80000000_00000000, 0) == 0x80000000_00000000
; run: %shr_i64(0x80000000_00000000, 1) == 0x40000000_00000000
; run: %shr_i64(0x80000000_00000000, 32) == 0x00000000_80000000
; run: %shr_i64(0x80000000_00000000, 63) == 1

function %uextend_i32_to_i64(i32) -> i64 {
block0(v0: i32):
    v1 = uextend.i64 v0
    return v1
}
; run: %uextend_i32_to_i64(0) == 0
; run: %uextend_i32_to_i64(0xFFFFFFFF) == 0x00000000_FFFFFFFF
; run: %uextend_i32_to_i64(0x12345678) == 0x00000000_12345678

function %sextend_i32_to_i64(i32) -> i64 {
