test compile precise-output
set opt_level=speed
target riscv32 has_m

function %mul_uextend_i32(i32, i32) -> i64 {
block0(v0: i32, v1: i32):
    v2 = uextend.i64 v0
    v3 = uextend.i64 v1
    v4 = imul v2, v3
    return v4
}

; VCode:
; block0:
;   mul a3,a0,a1
;   mulhu a1,a0,a1
;   mv a0,a3
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   mul a3, a0, a1
;   mulhu a1, a0, a1
;   mv a0, a3
;   ret

function %mul_sextend_i32(i32, i32) -> i64 {
block0(v0: i32, v1: i32):
    v2 = sextend.i64 v0
    v3 = sextend.i64 v1
    v4 = imul v2, v3
    return v4
}

; VCode:
; block0:
;   mul a3,a0,a1
;   mulh a1,a0,a1
;   mv a0,a3
;   ret
;
; Disassembled:
