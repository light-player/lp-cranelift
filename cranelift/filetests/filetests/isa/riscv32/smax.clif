; block0: ; offset 0x0
;   slli a3, a0, 0x38
;   srai a5, a3, 0x38
;   slli a1, a1, 0x38
;   srai a3, a1, 0x38
;   mv a0, a5
;   blt a3, a5, 8
;   mv a0, a3
;   ret

function %smax_i16(i16, i16) -> i16{
block0(v0: i16, v1: i16):
    v2 = smax v0, v1
    return v2
}

