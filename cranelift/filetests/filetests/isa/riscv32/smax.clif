test compile precise-output
set unwind_info=false
target riscv32 has_m

function %smax_i8(i8, i8) -> i8{
block0(v0: i8, v1: i8):
    v2 = smax v0, v1
    return v2
}

; VCode:
; block0:
;   slli a3,a0,56
;   srai a5,a3,56
;   slli a1,a1,56
;   srai a3,a1,56
;   select a0,a5,a3##condition=(a5 sgt a3)
;   ret
;
