; VCode:
; block0:
;   andi a4,a2,31
;   li a3,32
;   sub a3,a3,a4
;   sll a5,a1,a3
;   select a3,zero,a5##condition=(a4 eq zero)
;   srl a5,a0,a4
;   or a5,a3,a5
;   li t0,32
;   sra a3,a1,a4
;   andi a4,a2,63
;   srai a2,a1,31
;   select [a0,a1],[a3,a2],[a5,a3]##condition=(a4 uge t0)
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   andi a4, a2, 0x1f
;   addi a3, zero, 0x20
;   sub a3, a3, a4
;   sll a5, a1, a3
;   mv a3, zero
;   beqz a4, 8
;   mv a3, a5
;   srl a5, a0, a4
;   or a5, a3, a5
;   addi t0, zero, 0x20
;   sra a3, a1, a4
;   andi a4, a2, 0x3f
;   srai a2, a1, 0x1f
;   mv a0, a3
;   mv a1, a2
;   bgeu a4, t0, 0xc
;   mv a0, a5
;   mv a1, a3
;   ret

