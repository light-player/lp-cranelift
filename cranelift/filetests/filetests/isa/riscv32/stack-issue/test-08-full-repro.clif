test interpret
test run

set unwind_info=false
target riscv32 has_m

function %add_with_slot(i32 sret, i32, i32, i32, i32, i32, i32, i32, i32) system_v {
ss0 = explicit_slot 16, align = 4

block0(v0: i32, v1: i32, v2: i32, v3: i32, v4: i32, v5: i32, v6: i32, v7: i32, v8: i32):
    v9 = iadd v1, v2
    stack_store v9, ss0
    v10 = stack_load.i32 ss0
    v11 = iadd v10, v3
    store notrap aligned v11, v0
    return

block1:
    v12 = iconst.i32 0
    store notrap aligned v12, v0
    return
}

; function test:
function %test() -> i32 system_v {
ss0 = explicit_slot 16, align = 4
sig0 = (i32 sret, i32, i32, i32, i32, i32, i32, i32, i32) system_v
fn0 = colocated %add_with_slot sig0

block0:
    v10 = stack_addr.i32 ss0
    v11 = iconst.i32 1
    v12 = iconst.i32 2
    v13 = iconst.i32 3
    v14 = iconst.i32 4
    v15 = iconst.i32 5
    v16 = iconst.i32 6
    v17 = iconst.i32 7
    v18 = iconst.i32 8
    call fn0(v10, v11, v12, v13, v14, v15, v16, v17, v18)
    v19 = load.i32 notrap aligned v10
    return v19

block1:
    v20 = iconst.i32 0
    return v20
}

; function main:
function %main() -> i32 system_v {
sig0 = () -> i32 system_v
fn0 = colocated %test sig0

block0:
    v21 = call fn0()
    return v21

block1:
    v22 = iconst.i32 0
    return v22
}

; run: %main() == 6
