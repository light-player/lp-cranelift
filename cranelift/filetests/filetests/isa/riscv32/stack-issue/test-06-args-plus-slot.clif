test interpret
test run

set unwind_info=false
target riscv32 has_m

function %args_and_slot(i32, i32, i32, i32, i32, i32, i32, i32) -> i32 {
ss0 = explicit_slot 16, align = 4

block0(v0: i32, v1: i32, v2: i32, v3: i32, v4: i32, v5: i32, v6: i32, v7: i32):
    v8 = iadd v0, v1
    stack_store v8, ss0
    v9 = stack_load.i32 ss0
    v10 = iadd v9, v2
    return v10
}

; run: %args_and_slot(1, 2, 3, 4, 5, 6, 7, 8) == 6
