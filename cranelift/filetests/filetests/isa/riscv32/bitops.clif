;;;; i64 tests (2-register pattern on RV32)

function %clz_i64(i64) -> i64 {
block0(v0: i64):
    v1 = clz v0
    return v1
}

function %ctz_i64(i64) -> i64 {
block0(v0: i64):
    v1 = ctz v0
    return v1
}

function %cls_i64(i64) -> i64 {
