;   mv a5, a0
;   mv a0, zero
;   addi a3, zero, 0x10
;   addi a2, zero, 1
;   slli a2, a2, 0xf
;   blez a3, 0x1c
;   and t5, a2, a5
;   bne zero, t5, 0x14
;   addi a0, a0, 1
;   addi a3, a3, -1
;   srli a2, a2, 1
;   j -0x18
;   ret

