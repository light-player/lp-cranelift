test compile precise-output
set unwind_info=false
target riscv32 has_m

; Count leading zeros
function %clz_i8(i8) -> i8 {
block0(v0: i8):
    v1 = clz v0
    return v1
}

; VCode:
; block0:
;   mv a5,a0
;   clz a0,a5##ty=i8 tmp=a2 step=a3
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   mv a5, a0
;   mv a0, zero
;   addi a3, zero, 8
;   addi a2, zero, 1
;   slli a2, a2, 7
;   blez a3, 0x1c
;   and t5, a2, a5
;   bne zero, t5, 0x14
;   addi a0, a0, 1
;   addi a3, a3, -1
;   srli a2, a2, 1
;   j -0x18
;   ret

function %clz_i16(i16) -> i16 {
block0(v0: i16):
    v1 = clz v0
    return v1
}

; VCode:
; block0:
