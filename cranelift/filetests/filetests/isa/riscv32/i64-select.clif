test compile
target riscv32 has_m

;; Test i64 select operations (without precise-output to avoid ABI issues)

function %select_i64_simple(i8, i64, i64) -> i64 {
block0(v0: i8, v1: i64, v2: i64):
  v3 = select.i64 v0, v1, v2
  return v3
}

function %select_i64_with_icmp(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
  v2 = icmp eq v0, v1
  v3 = iconst.i64 1
  v4 = iconst.i64 0
  v5 = select.i64 v2, v3, v4
  return v5
}
