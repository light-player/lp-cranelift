; Test that unsupported instructions are rejected
test compile expect-fail
target riscv32 has_m

function %test_udiv_i64() {
block0:
    v0 = iconst.i64 10
    v1 = iconst.i64 2
    v2 = udiv v0, v1
    return
}

function %test_urem_i64() {
block0:
    v0 = iconst.i64 10
    v1 = iconst.i64 3
    v2 = urem v0, v1
    return
}

function %test_srem_i64() {
block0:
    v0 = iconst.i64 10
    v1 = iconst.i64 3
    v2 = srem v0, v1
    return
}

function %test_sdiv_i64() {
block0:
    v0 = iconst.i64 10
    v1 = iconst.i64 2
    v2 = sdiv v0, v1
    return
}
