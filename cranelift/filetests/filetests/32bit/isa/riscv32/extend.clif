;;;; i64 tests (2-register pattern on RV32)

function %uextend8_64(i8) -> i64 {
block0(v0: i8):
    v1 = uextend.i64 v0
    return v1
}

; VCode:
; block0:
;   andi a0,a0,255
;   li a1,0
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   andi a0, a0, 0xff
;   mv a1, zero
;   ret

function %uextend16_64(i16) -> i64 {
block0(v0: i16):
    v1 = uextend.i64 v0
    return v1
}

; VCode:
; block0:
;   slli a2,a0,48
;   srli a0,a2,48
;   li a1,0
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a2, a0, 0x30
;   srli a0, a2, 0x30
;   mv a1, zero
;   ret

function %uextend32_64(i32) -> i64 {
block0(v0: i32):
    v1 = uextend.i64 v0
    return v1
}

; VCode:
; block0:
;   slli a2,a0,32
;   srli a0,a2,32
;   li a1,0
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a2, a0, 0x20
;   srli a0, a2, 0x20
;   mv a1, zero
;   ret

function %sextend8_64(i8) -> i64 {
block0(v0: i8):
    v1 = sextend.i64 v0
    return v1
}

; VCode:
; block0:
;   slli a2,a0,56
;   srai a0,a2,56
;   srai a1,a0,31
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a2, a0, 0x38
;   srai a0, a2, 0x38
;   srai a1, a0, 0x1f
;   ret

function %sextend16_64(i16) -> i64 {
block0(v0: i16):
    v1 = sextend.i64 v0
    return v1
}

; VCode:
; block0:
;   slli a2,a0,48
;   srai a0,a2,48
;   srai a1,a0,31
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a2, a0, 0x30
;   srai a0, a2, 0x30
;   srai a1, a0, 0x1f
;   ret

function %sextend32_64(i32) -> i64 {
block0(v0: i32):
    v1 = sextend.i64 v0
    return v1
}

; VCode:
; block0:
;   slli a2,a0,32
;   srai a0,a2,32
;   srai a1,a0,31
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a2, a0, 0x20
;   srai a0, a2, 0x20
;   srai a1, a0, 0x1f
;   ret

