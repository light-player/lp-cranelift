test compile precise-output
set enable_multi_ret_implicit_sret
set unwind_info=false
target riscv32 has_m

function %call_i32(i32) -> i32 {
    fn0 = %g(i32) -> i32

block0(v0: i32):
    v1 = call fn0(v0)
    return v1
}

