test compile precise-output
set opt_level=speed
target riscv32 has_m

function %mul_uextend_i32(i32, i32) -> i64 {
block0(v0: i32, v1: i32):
    v2 = uextend.i64 v0
    v3 = uextend.i64 v1
    v4 = imul v2, v3
    return v4
}

; VCode:
; block0:
;   slli a3,a0,32
;   srli a5,a3,32
;   slli a1,a1,32
;   srli a3,a1,32
;   mul a0,a5,a3
;   mulhu a1,a5,a3
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a3, a0, 0x20
;   srli a5, a3, 0x20
;   slli a1, a1, 0x20
;   srli a3, a1, 0x20
;   mul a0, a5, a3
;   mulhu a1, a5, a3
;   ret

function %mul_sextend_i32(i32, i32) -> i64 {
block0(v0: i32, v1: i32):
    v2 = sextend.i64 v0
    v3 = sextend.i64 v1
    v4 = imul v2, v3
    return v4
}

; VCode:
; block0:
;   slli a3,a0,32
;   srai a5,a3,32
;   slli a1,a1,32
;   srai a3,a1,32
;   mul a0,a5,a3
;   mulh a1,a5,a3
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   slli a3, a0, 0x20
;   srai a5, a3, 0x20
;   slli a1, a1, 0x20
;   srai a3, a1, 0x20
;   mul a0, a5, a3
;   mulh a1, a5, a3
;   ret

function %smul_high_i32_pattern(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = sextend.i64 v0
    v3 = sextend.i64 v1
    v4 = imul v2, v3
    v5 = sshr_imm v4, 32
    v6 = ireduce.i32 v5
    return v6
}

; VCode:
; block0:
;   slli a3,a0,32
;   srai a5,a3,32
;   slli a1,a1,32
;   srai a3,a1,32
;   mul a5,a5,a3
;   srli a0,a5,32
;   ret
