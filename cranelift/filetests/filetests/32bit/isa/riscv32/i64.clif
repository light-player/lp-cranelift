; Disassembled:
; block0: ; offset 0x0
;   slli a3, a0, 0x20
;   srai a5, a3, 0x20
;   slli a1, a1, 0x20
;   srai a3, a1, 0x20
;   mul a5, a5, a3
;   srli a0, a5, 0x20
;   ret

function %smul_high_i32_isplit(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = sextend.i64 v0
    v3 = sextend.i64 v1
    v4 = imul v2, v3
    v5, v6 = isplit v4
    return v6
}

