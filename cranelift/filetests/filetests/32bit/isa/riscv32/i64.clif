function %umul_high_i32_pattern(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = uextend.i64 v0
    v3 = uextend.i64 v1
    v4 = imul v2, v3
    v5 = ushr_imm v4, 32
    v6 = ireduce.i32 v5
    return v6
}

