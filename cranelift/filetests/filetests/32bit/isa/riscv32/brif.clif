; Disassembled:
; block0: ; offset 0x0
;   andi a5, a0, 0xff
;   andi a1, a1, 0xff
;   beq a5, a1, 0xc
; block1: ; offset 0xc
;   mv a0, zero
;   ret
; block2: ; offset 0x14
;   addi a0, zero, 1
