;;;; i64 tests (2-register pattern on RV32)

function %ishl_i64_i8(i64, i8) -> i64 {
block0(v0: i64, v1: i8):
    v2 = ishl v0, v1
    return v2
}

; VCode:
; block0:
;   andi a5,a2,31
;   li a3,32
;   sub a3,a3,a5
;   sll a4,a0,a5
;   srl a0,a0,a3
;   select a3,zero,a0##condition=(a5 eq zero)
;   sll a5,a1,a5
;   or t0,a3,a5
;   li a3,32
;   andi a5,a2,63
;   select [a0,a1],[zero,a4],[a4,t0]##condition=(a5 uge a3)
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   andi a5, a2, 0x1f
;   addi a3, zero, 0x20
;   sub a3, a3, a5
;   sll a4, a0, a5
;   srl a0, a0, a3
;   mv a3, zero
;   beqz a5, 8
;   mv a3, a0
;   sll a5, a1, a5
;   or t0, a3, a5
;   addi a3, zero, 0x20
;   andi a5, a2, 0x3f
;   mv a0, zero
;   mv a1, a4
;   bgeu a5, a3, 0xc
;   mv a0, a4
;   mv a1, t0
;   ret

function %ishl_i64_i16(i64, i16) -> i64 {
block0(v0: i64, v1: i16):
    v2 = ishl v0, v1
    return v2
}

