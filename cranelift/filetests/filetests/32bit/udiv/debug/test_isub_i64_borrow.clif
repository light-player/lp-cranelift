test interpret
test run
target riscv32 has_m has_zbb

; Test i64 subtraction with borrow propagation
; This tests the 2-register pattern used in riscv32 lowering
; The lowering uses: diff_lo = sub x_lo, y_lo; borrow = sltu x_lo, diff_lo; diff_hi = sub x_hi, y_hi; diff_hi = sub diff_hi, borrow
; The execution log shows this pattern producing wrong results
function %test_isub_i64_borrow(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = isub v0, v1
    return v2
}

; Test cases that should work correctly
; run: %test_isub_i64_borrow(0x0000000000000020, 0x0000000000000000) == 32
; run: %test_isub_i64_borrow(0x000000000000001f, 0x0000000000000000) == 31
; run: %test_isub_i64_borrow(0x0000000100000000, 0x0000000000000001) == 0x00000000ffffffff
; run: %test_isub_i64_borrow(0x0000000100000000, 0x0000000000000000) == 0x0000000100000000
; run: %test_isub_i64_borrow(0x00000000ffffffff, 0x0000000000000001) == 0x00000000fffffffe
; run: %test_isub_i64_borrow(0x0000000000000000, 0x0000000000000000) == 0

