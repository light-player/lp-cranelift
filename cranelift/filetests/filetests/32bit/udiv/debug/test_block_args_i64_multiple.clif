test interpret
test run
target riscv32 has_m has_zbb

; Test multiple i64 block arguments - this matches block5's signature
; block5(v31: i64, v32: i64, v76: i32, v77: i32, v79: i32)
; The bug might be in how the i64 arguments are passed/accessed
function %test_block_args_i64_multiple(i64, i64, i32, i32, i32) -> i64 {
block0(v0: i64, v1: i64, v2: i32, v3: i32, v4: i32):
    ; Pass all arguments to another block
    jump block1(v0, v1, v2, v3, v4)
block1(v5: i64, v6: i64, v7: i32, v8: i32, v9: i32):
    ; Do the subtraction that's failing
    v10 = isub v5, v6
    return v10
}

; Test cases
; run: %test_block_args_i64_multiple(0x0000000000000064, 0x0000000000000032, 0, 0, 0) == 50
; run: %test_block_args_i64_multiple(0x0000000000000000, 0x0000000000000000, 0, 0, 0) == 0




