test interpret
test run
target riscv32 has_m has_zbb

; Test i64 subtraction with constant - demonstrates the bug
; This is the pattern from block3: v24 = isub v22, v23 where v22 = 32
; The execution log shows: sub s5, a0, a3 where s5: 32 -> -1
; This suggests the borrow detection is wrong when subtracting from a constant
function %test_isub_const_borrow_bug(i64) -> i64 {
block0(v0: i64):
    v1 = iconst.i64 32
    v2 = isub v1, v0
    return v2
}

; Test cases that demonstrate the bug
; When v0 is a zero-extended negative i32, it becomes a huge positive u64
; Example: v0 = 0x00000000fffffffe (zero-extended -2)
; 32 - 0x00000000fffffffe should be computed correctly
; But with wrong borrow detection, the high part calculation goes wrong
; run: %test_isub_const_borrow_bug(0x0000000000000000) == 32
; run: %test_isub_const_borrow_bug(0x0000000000000001) == 31
; run: %test_isub_const_borrow_bug(0x000000000000001f) == 1
; run: %test_isub_const_borrow_bug(0x0000000000000020) == 0

; The problematic case: zero-extended negative i32
; This is what happens in the normalization shift calculation
; v0 = 0x00000000fffffffe (zero-extended -2 from i32)
; 32 - 0x00000000fffffffe = -4294967262 (interpreter result)
; The bug in borrow detection would show up when there's a borrow from high part
; run: %test_isub_const_borrow_bug(0x00000000fffffffe) == -4294967262

