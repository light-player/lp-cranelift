test interpret
test run
target riscv32 has_m has_zbb

; Test i64 subtraction - this is the main suspect from the execution log
; The log shows: sub s5, a0, a3 where s5: 32 -> -1 (wrong!)
function %test_isub_i64(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = isub v0, v1
    return v2
}

; Test cases covering the problematic scenarios
; run: %test_isub_i64(32, 0) == 32
; run: %test_isub_i64(0x0000000000000020, 0x0000000000000000) == 32
; run: %test_isub_i64(31, 0) == 31
; run: %test_isub_i64(0x000000000000001f, 0x0000000000000000) == 31
; run: %test_isub_i64(0, 0) == 0
; run: %test_isub_i64(100, 50) == 50
; run: %test_isub_i64(0x0000000000000064, 0x0000000000000032) == 50

