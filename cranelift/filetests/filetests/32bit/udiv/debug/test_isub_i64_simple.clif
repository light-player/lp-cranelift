test interpret
test run
target riscv32 has_m has_zbb

; Simple test: just return the subtraction result directly
; This will show if the subtraction itself is wrong
function %test_isub_i64_simple(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = isub v0, v1
    return v2
}

; Basic test cases
; run: %test_isub_i64_simple(0x0000000000000064, 0x0000000000000032) == 50
; run: %test_isub_i64_simple(0x0000000000000000, 0x0000000000000000) == 0
; run: %test_isub_i64_simple(0x0000000000000001, 0x0000000000000002) == 0xffffffffffffffff




