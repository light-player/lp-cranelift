test interpret
test run
target riscv32 has_m has_zbb

; Test icmp sle with i64, specifically the pattern from block5
; v35 = icmp sle v34, v33 where v34 = 0
; This is used to check if the subtraction result is >= 0
function %test_icmp_sle_i64_zero(i64) -> i32 {
block0(v0: i64):
    v1 = iconst.i64 0
    v2 = icmp sle v1, v0
    v3 = uextend.i32 v2
    return v3
}

; Test cases
; run: %test_icmp_sle_i64_zero(0) == 1
; run: %test_icmp_sle_i64_zero(1) == 1
; run: %test_icmp_sle_i64_zero(-1) == 0
; run: %test_icmp_sle_i64_zero(0xffffffffffffffff) == 0
; run: %test_icmp_sle_i64_zero(0x0000000000000064) == 1

