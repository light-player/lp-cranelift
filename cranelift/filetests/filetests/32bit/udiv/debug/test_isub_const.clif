test interpret
test run
target riscv32 has_m has_zbb

; Test i64 subtraction with constant (pattern from block3)
; block3: v24 = isub v22, v23 where v22 = 32 (constant)
; This is the specific pattern that's failing
function %test_isub_const(i64) -> i64 {
block0(v0: i64):
    v1 = iconst.i64 32
    v2 = isub v1, v0
    return v2
}

; Test cases
; run: %test_isub_const(0) == 32
; run: %test_isub_const(1) == 31
; run: %test_isub_const(31) == 1
; run: %test_isub_const(32) == 0
; run: %test_isub_const(33) == 0xffffffffffffffff  ; -1 as i64
; run: %test_isub_const(0x0000000000000020) == 0

