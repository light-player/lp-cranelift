test interpret
test run
set enable_multi_ret_implicit_sret
target riscv32 has_m


; ===== TWO RETURNS (BOTH IN REGISTERS) =====

function %two_i32(i32, i32) -> i32, i32 {
block0(v0: i32, v1: i32):
    return v0, v1
}
; run: %two_i32(1, 2) == [1, 2]

function %two_i8(i8, i8) -> i8, i8 {
block0(v0: i8, v1: i8):
    return v0, v1
}
; run: %two_i8(1, 2) == [1, 2]

function %two_i16(i16, i16) -> i16, i16 {
block0(v0: i16, v1: i16):
    return v0, v1
}
; run: %two_i16(1, 2) == [1, 2]

function %two_i64(i64, i64) -> i64, i64 {
block0(v0: i64, v1: i64):
    return v0, v1
}
; run: %two_i64(100, 200) == [100, 200]


; ===== THREE RETURNS (TWO REGISTERS, ONE STACK) =====

