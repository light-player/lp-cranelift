    return v0, v1, v2
}
; run: %three_i32(1, 2, 3) == [1, 2, 3]

function %three_mixed_i8_i32(i8, i32, i8) -> i8, i32, i8 {
block0(v0: i8, v1: i32, v2: i8):
    return v0, v1, v2
}
; run: %three_mixed_i8_i32(1, 42, 3) == [1, 42, 3]


; ===== FOUR RETURNS (TWO REGISTERS, TWO STACK) =====

function %four_i8(i8, i8, i8, i8) -> i8, i8, i8, i8 {
block0(v0: i8, v1: i8, v2: i8, v3: i8):
    return v0, v1, v2, v3
}
; run: %four_i8(1, 2, 3, 4) == [1, 2, 3, 4]

