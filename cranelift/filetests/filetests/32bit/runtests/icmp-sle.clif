; Test comparisons against zero - this is the bug case
function %icmp_sle_i64_zero(i64) -> i8 {
block0(v0: i64):
    v1 = iconst.i64 0
    v2 = icmp sle v1, v0  ; Check if v0 >= 0
    return v2
}
; run: %icmp_sle_i64_zero(0) == 1
; run: %icmp_sle_i64_zero(1) == 1
; run: %icmp_sle_i64_zero(-1) == 0
; run: %icmp_sle_i64_zero(0x7fffffff) == 1  ; Max positive i32
; run: %icmp_sle_i64_zero(0xffffffff80000000) == 0  ; Min negative i32 sign-extended to i64 (-2147483648)
; run: %icmp_sle_i64_zero(0xffffffffffffffff) == 0  ; -1 sign-extended to i64
; run: %icmp_sle_i64_zero(0x100000000) == 1  ; 2^32 (positive in i64)
; run: %icmp_sle_i64_zero(0x8000000000000000) == 0  ; Min negative i64

