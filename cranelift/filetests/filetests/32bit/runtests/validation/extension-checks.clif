; Test that instructions requiring extensions are rejected when extensions aren't enabled
test compile
target riscv32

function %test_sdiv_requires_m(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = sdiv v0, v1
    return v2
}

; This should fail with validation error: Missing required extension M for sdiv

function %test_imul_requires_m(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = imul v0, v1
    return v2
}

; This should fail with validation error: Missing required extension M for imul

function %test_srem_requires_m(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = srem v0, v1
    return v2
}

; This should fail with validation error: Missing required extension M for srem

function %test_udiv_requires_m(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = udiv v0, v1
    return v2
}

; This should fail with validation error: Missing required extension M for udiv

function %test_urem_requires_m(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = urem v0, v1
    return v2
}

; This should fail with validation error: Missing required extension M for urem
